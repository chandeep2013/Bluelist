<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog
        id="chatbotDialog"
        showHeader="true"
        contentWidth="380px"
        contentHeight="480px"
        resizable="true"
        draggable="true"
        stretch="false"
        class="chatbotDialog">

        <customHeader>
            <Bar>
                <contentLeft>
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://da" class="sapUiTinyMarginEnd chatbotHeaderIcon"/>
                        <Title text="Bluelist Assistant" level="H5"/>
                    </HBox>
                </contentLeft>
                <contentRight>
                    <Button icon="sap-icon://delete" press=".onChatbotClear" tooltip="Clear Chat" type="Transparent"/>
                    <Button icon="sap-icon://decline" press=".onChatbotClose" type="Transparent"/>
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <VBox class="chatbotBody" height="100%">
                <!-- Messages area -->
                <ScrollContainer
                    id="chatScrollContainer"
                    height="100%"
                    width="100%"
                    vertical="true"
                    horizontal="false"
                    class="chatMessagesScroll">
                    <VBox id="chatMessagesBox" class="chatMessagesBox">
                        <!-- Messages are added dynamically -->
                    </VBox>
                </ScrollContainer>

                <!-- Quick actions -->
                <HBox id="chatQuickActions" class="chatQuickActions" wrap="Wrap" visible="true">
                    <Button text="Request Status" press=".onQuickAction" type="Ghost" class="chatQuickBtn"/>
                    <Button text="Search Tips" press=".onQuickAction" type="Ghost" class="chatQuickBtn"/>
                    <Button text="My Stats" press=".onQuickAction" type="Ghost" class="chatQuickBtn"/>
                    <Button text="Help" press=".onQuickAction" type="Ghost" class="chatQuickBtn"/>
                </HBox>

                <!-- Input area -->
                <HBox class="chatInputArea" alignItems="Center">
                    <TextArea
                        id="chatInput" 
                        placeholder="Type a message..."
                        width="295px"
                        class="chatInputField"/>
                    <Button
                        icon="sap-icon://feeder-arrow"
                        press=".onChatSend"
                        type="Emphasized"
                        class="chatSendBtn"/>
                </HBox>
            </VBox>
        </content>
    </Dialog>

</core:FragmentDefinition>
