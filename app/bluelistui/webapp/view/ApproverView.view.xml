<mvc:View controllerName="com.bgsw.bluelistui.controller.ApproverView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core">
    <Page id="approverPage" title="Approve Access Requests" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Smart Filter Bar -->
                <smartFilterBar:SmartFilterBar id="approverSmartFilterBar"
                    entitySet="Requests"
                    persistencyKey="SmartFilter_ApproverRequests"
                    basicSearchFieldName="FullName"
                    showFilterConfiguration="true"
                    useToolbar="true">
                    <smartFilterBar:controlConfiguration>
                        <smartFilterBar:ControlConfiguration key="Project_ProjectID" label="Project" visibleInAdvancedArea="true" index="1">
                            <smartFilterBar:customControl>
                                <Select id="approverFilterProject"
                                    forceSelection="false"
                                    selectedKey="{approverFilterModel>/Project_ProjectID}"
                                    items="{/Projects}">
                                    <core:Item key="{ProjectID}" text="{ProjectName}"/>
                                </Select>
                            </smartFilterBar:customControl>
                        </smartFilterBar:ControlConfiguration>
                        <smartFilterBar:ControlConfiguration key="Table_TableID" label="Table" visibleInAdvancedArea="true" index="2">
                            <smartFilterBar:customControl>
                                <Select id="approverFilterTable"
                                    forceSelection="false"
                                    selectedKey="{approverFilterModel>/Table_TableID}"
                                    items="{/Tables}">
                                    <core:Item key="{TableID}" text="{TableName}"/>
                                </Select>
                            </smartFilterBar:customControl>
                        </smartFilterBar:ControlConfiguration>
                    </smartFilterBar:controlConfiguration>
                </smartFilterBar:SmartFilterBar>

                <!-- Smart Table -->
                <smartTable:SmartTable id="approverSmartTable"
                    entitySet="Requests"
                    smartFilterId="approverSmartFilterBar"
                    tableType="ResponsiveTable"
                    header="Pending Approval Requests"
                    showRowCount="true"
                    enableAutoBinding="true"
                    enableExport="true"
                    showFullScreenButton="true"
                    useExportToExcel="true"
                    useVariantManagement="false"
                    useTablePersonalisation="true"
                    persistencyKey="SmartTable_ApproverRequests"
                    demandPopin="true"
                    initiallyVisibleFields="RequestNo,FullName,NTID,MailID,Project_ProjectID,Table_TableID,TrainingStatus,Status,AccessFromDate,AccessEndDate,Comments"
                    beforeRebindTable=".onBeforeRebindTable"
                    initialise=".onSmartTableInit">
                    <smartTable:customToolbar>
                        <OverflowToolbar>
                            <ToolbarSpacer/>
                            <Button id="btnApprove"
                                text="Approve"
                                icon="sap-icon://accept"
                                type="Accept"
                                press=".onApproveRequest"/>
                            <Button id="btnReject"
                                text="Reject"
                                icon="sap-icon://decline"
                                type="Reject"
                                press=".onRejectRequest"/>
                            <Button id="btnSendBack"
                                text="Send Back"
                                icon="sap-icon://undo"
                                press=".onSendBackRequest"/>
                        </OverflowToolbar>
                    </smartTable:customToolbar>
                </smartTable:SmartTable>
            </VBox>
        </content>
    </Page>
</mvc:View>
